<UserControl
    x:Class="NotesTaskView.Controls.FolderIconControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="112"
    Height="88"
    SnapsToDevicePixels="True">
    <Grid>
        <Ellipse
            Width="110"
            Height="64"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Fill="{DynamicResource AccentVerySoftBrush}"
            Opacity="0.95" />

        <Border
            Width="94"
            Height="54"
            Margin="8,26,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            CornerRadius="14"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1.4">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF303247" Offset="0" />
                    <GradientStop Color="#F0181927" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border
            Width="42"
            Height="22"
            Margin="12,14,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            CornerRadius="13,13,8,8"
            Background="{DynamicResource AccentSoftBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1.2" />

        <Border
            Width="96"
            Height="48"
            Margin="8,34,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            CornerRadius="14"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1.6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F03A3B52" Offset="0" />
                    <GradientStop Color="#F0151624" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border
            Width="78"
            Height="2"
            Margin="18,40,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{DynamicResource AccentSoftBrush}"
            CornerRadius="1"
            Opacity="0.75" />
    </Grid>
</UserControl>
