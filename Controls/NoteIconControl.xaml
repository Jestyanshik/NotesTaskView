<UserControl
    x:Class="NotesTaskView.Controls.NoteIconControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="96"
    Height="104"
    SnapsToDevicePixels="True">
    <Grid>
        <Ellipse
            Width="92"
            Height="74"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Fill="{DynamicResource AccentVerySoftBrush}" />

        <Path
            Stretch="Fill"
            Width="74"
            Height="88"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Data="M 10,0 L 50,0 L 74,24 L 74,78 Q 74,88 64,88 L 10,88 Q 0,88 0,78 L 0,10 Q 0,0 10,0 Z"
            Stroke="{DynamicResource AccentBorderBrush}"
            StrokeThickness="1.5">
            <Path.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0383A50" Offset="0" />
                    <GradientStop Color="#F0141524" Offset="1" />
                </LinearGradientBrush>
            </Path.Fill>
        </Path>

        <Path
            Stretch="Fill"
            Width="26"
            Height="26"
            Margin="0,8,14,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Data="M 0,0 L 26,26 L 8,26 Q 0,26 0,18 Z"
            Fill="{DynamicResource AccentSoftBrush}"
            Stroke="{DynamicResource AccentBorderBrush}"
            StrokeThickness="1" />

        <StackPanel
            Width="46"
            Margin="0,42,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <Border Height="4" Margin="0,0,0,11" Background="{DynamicResource AccentSoftBrush}" CornerRadius="2" />
            <Border Height="4" Margin="0,0,0,11" Background="{DynamicResource AccentSoftBrush}" CornerRadius="2" Opacity="0.9" />
            <Border Height="4" Margin="0,0,0,11" Background="{DynamicResource AccentSoftBrush}" CornerRadius="2" Opacity="0.8" />
            <Border Width="30" Height="4" HorizontalAlignment="Left" Background="{DynamicResource AccentSoftBrush}" CornerRadius="2" Opacity="0.75" />
        </StackPanel>
    </Grid>
</UserControl>
