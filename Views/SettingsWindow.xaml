<Window
    x:Class="NotesTaskView.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:NotesTaskView.Models"
    Title="Настройки"
    Width="760"
    Height="720"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True"
    FontFamily="Segoe UI"
    PreviewKeyDown="Window_PreviewKeyDown">
    <Border
        Margin="20"
        Padding="26"
        Background="#F0111118"
        BorderBrush="#3630303A"
        BorderThickness="1"
        CornerRadius="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Text="Настройки"
                Foreground="{StaticResource PrimaryTextBrush}"
                FontSize="26"
                FontWeight="SemiBold" />

            <Border
                x:Name="SettingsStatusBorder"
                Grid.Row="0"
                Margin="170,3,0,0"
                Padding="12,7"
                HorizontalAlignment="Left"
                Background="#FF202028"
                CornerRadius="10"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="SettingsStatusText"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    FontSize="13"
                    TextWrapping="Wrap" />
            </Border>

            <ScrollViewer Grid.Row="1" Margin="0,22,0,20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        Text="Название overlay"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13" />
                    <TextBox
                        x:Name="OverlayTitleTextBox"
                        Margin="0,8,0,16"
                        Padding="12,9"
                        Background="#FF181820"
                        BorderBrush="#FF30303A"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CaretBrush="{StaticResource PrimaryTextBrush}" />

                    <TextBlock
                        Text="Папка заметок"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13" />
                    <TextBox
                        x:Name="NotesDirectoryTextBox"
                        Margin="0,8,0,16"
                        Padding="12,9"
                        Background="#FF181820"
                        BorderBrush="#FF30303A"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CaretBrush="{StaticResource PrimaryTextBrush}" />

                    <TextBlock
                        Text="Горячая клавиша overlay"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13" />
                    <TextBox
                        x:Name="ToggleHotkeyTextBox"
                        Margin="0,8,0,16"
                        Padding="12,9"
                        Background="#FF181820"
                        BorderBrush="#FF30303A"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CaretBrush="{StaticResource PrimaryTextBrush}" />

                    <TextBlock
                        Text="Горячая клавиша новой заметки"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13" />
                    <TextBox
                        x:Name="NewNoteHotkeyTextBox"
                        Margin="0,8,0,16"
                        Padding="12,9"
                        Background="#FF181820"
                        BorderBrush="#FF30303A"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CaretBrush="{StaticResource PrimaryTextBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="Затемнение фона"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="13" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding ElementName=DimOpacitySlider, Path=Value, StringFormat={}{0:0.00}}"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="13" />
                    </Grid>
                    <Slider
                        x:Name="DimOpacitySlider"
                        Margin="0,10,0,24"
                        Minimum="0.00"
                        Maximum="0.75"
                        TickFrequency="0.01"
                        Value="0.08" />

                    <TextBlock
                        Text="Цвет рамки выделения"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13" />
                    <TextBox
                        x:Name="SelectionOutlineColorTextBox"
                        Margin="0,8,0,16"
                        Padding="12,9"
                        Background="#FF181820"
                        BorderBrush="#FF30303A"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CaretBrush="{StaticResource PrimaryTextBrush}" />

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="Мусорка"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            FontSize="20"
                            FontWeight="SemiBold" />
                        <Button
                            Grid.Column="1"
                            Click="EmptyTrashButton_OnClick"
                            Style="{StaticResource DangerButtonStyle}"
                            Content="Очистить мусорку" />
                    </Grid>

                    <ItemsControl x:Name="TrashItemsControl" ItemsSource="{Binding TrashItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TrashItem}">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    Background="#FF181820"
                                    BorderBrush="#FF30303A"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock
                                                Text="{Binding DisplayName}"
                                                Foreground="{StaticResource PrimaryTextBrush}"
                                                FontWeight="SemiBold"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Text="{Binding OriginalPath}"
                                                Foreground="{StaticResource SecondaryTextBrush}"
                                                FontSize="12"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Text="{Binding DisplayDeletedAt}"
                                                Foreground="{StaticResource SecondaryTextBrush}"
                                                FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button
                                                Tag="{Binding}"
                                                Margin="0,0,8,0"
                                                Click="RestoreTrashButton_OnClick"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Content="Восстановить" />
                                            <Button
                                                Tag="{Binding}"
                                                Click="DeleteForeverButton_OnClick"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Content="Удалить навсегда" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="108"
                    Margin="0,0,10,0"
                    Click="CancelButton_OnClick"
                    Style="{StaticResource ActionButtonStyle}"
                    Content="Отмена" />
                <Button
                    Width="118"
                    Click="SaveButton_OnClick"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Сохранить" />
            </StackPanel>

            <Grid
                x:Name="SettingsConfirmOverlay"
                Grid.RowSpan="3"
                Background="#66000000"
                Visibility="Collapsed">
                <Border
                    Width="420"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FF181820"
                    BorderBrush="#FF343442"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel>
                        <TextBlock
                            x:Name="SettingsConfirmTitleText"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            FontSize="21"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="SettingsConfirmMessageText"
                            Margin="0,12,0,20"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            TextWrapping="Wrap" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button
                                x:Name="SettingsConfirmCancelButton"
                                Width="110"
                                Margin="0,0,10,0"
                                Click="SettingsConfirmCancelButton_OnClick"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="Отмена" />
                            <Button
                                x:Name="SettingsConfirmOkButton"
                                Width="120"
                                Click="SettingsConfirmOkButton_OnClick"
                                Style="{StaticResource DangerButtonStyle}"
                                Content="Удалить" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
