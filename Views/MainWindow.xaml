        <Grid
            x:Name="ModalOverlay"
            Panel.ZIndex="100"
            Background="#66000000"
            Visibility="Collapsed">
            <Border
                Width="440"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FF181820"
                BorderBrush="#FF343442"
                BorderThickness="1"
                CornerRadius="16">
                <StackPanel>
                    <TextBlock
                        x:Name="ModalTitleText"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        FontSize="22"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="ModalMessageText"
                        Margin="0,12,0,22"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="14"
                        TextWrapping="Wrap" />
                    <StackPanel
                        x:Name="ModalButtonsPanel"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
