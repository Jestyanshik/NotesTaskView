                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="FolderPickerPrevButton"
                            Width="34"
                            Height="84"
                            Click="FolderPickerPrevButton_OnClick"
